# FinLeaf — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — add it to .gitignore

# ── STRIPE ──────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Get this after adding your webhook endpoint in the Stripe dashboard
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── PRICE IDs ───────────────────────────────────────────────────────
# Create these in: https://dashboard.stripe.com/products
# Add a product called "FinLeaf Pro" with two prices:
#   Monthly: $12.00 CAD / month   → recurring
#   Annual:  $96.00 CAD / year    → recurring
STRIPE_PRICE_MONTHLY=price_1TjUBjDRfUZXnjHseNy40Qwh
STRIPE_PRICE_ANNUAL=price_1TjUBjDRfUZXnjHsbETWuVII

# ── APP ─────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=https://yourdomain.com

# ── EMAIL (optional — for welcome emails) ───────────────────────────
# Sign up at: https://sendgrid.com (free tier: 100 emails/day)
SENDGRID_API_KEY=SG.YOUR_SENDGRID_KEY_HERE

# ── FILE DOWNLOADS ──────────────────────────────────────────────────
# Host your Excel files on Dropbox, Google Drive, or S3 and paste the link here
FREE_TEMPLATE_DOWNLOAD_URL=https://your-download-link.com/free-kit.xlsx
PRO_DOWNLOAD_URL=https://your-download-link.com/pro-kit.xlsx
